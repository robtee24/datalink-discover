# Extensionless URLs for static HTML (Apache / compatible hosts).
# Vercel: use vercel.json cleanUrls instead; this file is ignored there.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L,QSA]
</IfModule>
